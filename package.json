{
  "name": "heychef-backend",
  "version": "1.0.0",
  "description": "HeyChef - Digital Menu + QR Code Orders SaaS",
  "main": "dist/infra/server.js",
  "scripts": {
    "dev": "tsx watch src/infra/server.ts",
    "build": "tsc",
    "start": "node dist/infra/server.js",
    "migrate": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "seed": "tsx src/infra/seed.ts",
